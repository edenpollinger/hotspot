<!DOCTYPE html>

<html dir="rtl" lang="he"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#2b8cee",
                        "background-light": "#f6f7f8",
                        "background-dark": "#101922",
                    },
                    fontFamily: {
                        "display": ["Inter", "sans-serif"]
                    },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
                },
            },
        }
    </script>
<style>
        body {
            font-family: 'Inter', sans-serif;
        }
        .mac-shadow {
            box-shadow: 0 10px 30px -10px rgba(0,0,0,0.1), 0 4px 6px -4px rgba(0,0,0,0.05);
        }
        .custom-scrollbar::-webkit-scrollbar {
            width: 6px;
        }
        .custom-scrollbar::-webkit-scrollbar-track {
            background: transparent;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: #e2e8f0;
            border-radius: 10px;
        }
    </style>
</head>
<body class="bg-background-light dark:bg-background-dark min-h-screen text-slate-900 dark:text-slate-100 antialiased font-display">
<!-- Main Container -->
<div class="max-w-[1200px] mx-auto px-4 py-8">
<!-- Header Section -->
<header class="mb-8 flex flex-col md:flex-row md:items-end justify-between gap-6">
<div class="space-y-2">
<div class="flex items-center gap-3 text-primary mb-2">
<span class="material-symbols-outlined text-3xl">add_business</span>
<span class="text-sm font-bold uppercase tracking-wider bg-primary/10 px-3 py-1 rounded-full">ניהול משאבים</span>
</div>
<h1 class="text-4xl font-black tracking-tight text-slate-900 dark:text-white">הוספת משאב חדש</h1>
<p class="text-slate-500 dark:text-slate-400 text-lg">הגדר חדר או עמדת עבודה חדשה ושייך אותם לסביבת העבודה שלך.</p>
</div>
<div class="flex flex-col items-end gap-2 min-w-[240px]">
<div class="flex justify-between w-full text-sm font-semibold px-1">
<span>שלב 1: הגדרת משאב</span>
<span class="text-primary">33%</span>
</div>
<div class="w-full h-3 bg-slate-200 dark:bg-slate-800 rounded-full overflow-hidden">
<div class="h-full bg-primary w-1/3 rounded-full"></div>
</div>
</div>
</header>
<div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
<!-- Left Column: Forms -->
<div class="lg:col-span-7 space-y-6">
<!-- Workspace Selection -->
<section class="bg-white dark:bg-slate-900 p-6 rounded-xl mac-shadow border border-slate-100 dark:border-slate-800">
<h2 class="text-lg font-bold mb-4 flex items-center gap-2">
<span class="material-symbols-outlined text-primary">hub</span>
                        בחירת סביבת עבודה (Workspace)
                    </h2>
<div class="relative">
<select class="w-full p-4 pr-12 rounded-lg border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all appearance-none font-medium">
<option value="">בחר סביבת עבודה...</option>
<option selected="" value="tel-aviv">מטה תל אביב (HQ)</option>
<option value="london">סניף לונדון</option>
<option value="new-york">משרד ניו יורק</option>
</select>
<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">expand_more</span>
<span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-primary">location_on</span>
</div>
</section>
<!-- Resource Type -->
<section class="bg-white dark:bg-slate-900 p-6 rounded-xl mac-shadow border border-slate-100 dark:border-slate-800">
<h2 class="text-lg font-bold mb-4 flex items-center gap-2">
<span class="material-symbols-outlined text-primary">category</span>
                        סוג המשאב
                    </h2>
<div class="grid grid-cols-3 gap-4">
<label class="cursor-pointer group">
<input checked="" class="hidden peer" name="type" type="radio"/>
<div class="flex flex-col items-center gap-3 p-4 rounded-xl border-2 border-slate-100 dark:border-slate-800 bg-slate-50 dark:bg-slate-800 peer-checked:border-primary peer-checked:bg-primary/5 transition-all">
<span class="material-symbols-outlined text-3xl text-orange-500 bg-orange-100 p-3 rounded-lg">meeting_room</span>
<span class="font-bold text-sm">חדר ישיבות</span>
</div>
</label>
<label class="cursor-pointer group">
<input class="hidden peer" name="type" type="radio"/>
<div class="flex flex-col items-center gap-3 p-4 rounded-xl border-2 border-slate-100 dark:border-slate-800 bg-slate-50 dark:bg-slate-800 peer-checked:border-primary peer-checked:bg-primary/5 transition-all">
<span class="material-symbols-outlined text-3xl text-blue-500 bg-blue-100 p-3 rounded-lg">desk</span>
<span class="font-bold text-sm">עמדת עבודה</span>
</div>
</label>
<label class="cursor-pointer group">
<input class="hidden peer" name="type" type="radio"/>
<div class="flex flex-col items-center gap-3 p-4 rounded-xl border-2 border-slate-100 dark:border-slate-800 bg-slate-50 dark:bg-slate-800 peer-checked:border-primary peer-checked:bg-primary/5 transition-all">
<span class="material-symbols-outlined text-3xl text-purple-500 bg-purple-100 p-3 rounded-lg">corporate_fare</span>
<span class="font-bold text-sm">משרד פרטי</span>
</div>
</label>
</div>
</section>
<!-- Basic Info -->
<section class="bg-white dark:bg-slate-900 p-6 rounded-xl mac-shadow border border-slate-100 dark:border-slate-800 space-y-4">
<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
<div class="space-y-1">
<label class="text-sm font-bold mr-1">שם המשאב</label>
<input class="w-full p-3 rounded-lg border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 focus:ring-2 focus:ring-primary/20" placeholder="למשל: חדר ישיבות אלון" type="text"/>
</div>
<div class="space-y-1">
<label class="text-sm font-bold mr-1">מזהה משאב / Tag</label>
<input class="w-full p-3 rounded-lg border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 focus:ring-2 focus:ring-primary/20" placeholder="MR-402" type="text"/>
</div>
</div>
<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
<div class="space-y-1">
<label class="text-sm font-bold mr-1">בחירת קומה</label>
<select class="w-full p-3 rounded-lg border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 focus:ring-2 focus:ring-primary/20">
<option>קומה 4</option>
<option>קומה 5</option>
<option>קומה 6</option>
</select>
</div>
<div class="space-y-1">
<div class="flex justify-between mb-1">
<label class="text-sm font-bold mr-1">קיבולת (אנשים)</label>
<span class="text-primary font-bold">8</span>
</div>
<input class="w-full h-2 bg-slate-200 rounded-lg appearance-none cursor-pointer accent-primary" max="50" min="1" type="range" value="8"/>
</div>
</div>
</section>
<!-- Amenities -->
<section class="bg-white dark:bg-slate-900 p-6 rounded-xl mac-shadow border border-slate-100 dark:border-slate-800">
<h2 class="text-lg font-bold mb-4 flex items-center gap-2">
<span class="material-symbols-outlined text-primary">inventory_2</span>
                        אבזור ושירותים
                    </h2>
<div class="flex flex-wrap gap-2">
<button class="flex items-center gap-2 px-4 py-2 rounded-full border border-slate-200 dark:border-slate-700 hover:border-primary hover:bg-primary/5 transition-all">
<span class="material-symbols-outlined text-cyan-500 text-sm">monitor</span>
<span class="text-sm font-medium">מסך כפול</span>
</button>
<button class="flex items-center gap-2 px-4 py-2 rounded-full bg-primary/10 border border-primary text-primary transition-all">
<span class="material-symbols-outlined text-sm">videocam</span>
<span class="text-sm font-medium">שיחות וידאו</span>
<span class="material-symbols-outlined text-xs">check_circle</span>
</button>
<button class="flex items-center gap-2 px-4 py-2 rounded-full border border-slate-200 dark:border-slate-700 hover:border-primary hover:bg-primary/5 transition-all">
<span class="material-symbols-outlined text-emerald-500 text-sm">developer_board</span>
<span class="text-sm font-medium">לוח מחיק</span>
</button>
<button class="flex items-center gap-2 px-4 py-2 rounded-full border border-slate-200 dark:border-slate-700 hover:border-primary hover:bg-primary/5 transition-all">
<span class="material-symbols-outlined text-brown-500 text-sm">coffee</span>
<span class="text-sm font-medium">מכונת קפה</span>
</button>
<button class="flex items-center gap-2 px-4 py-2 rounded-full bg-primary/10 border border-primary text-primary transition-all">
<span class="material-symbols-outlined text-sm">wifi</span>
<span class="text-sm font-medium">WiFi מהיר</span>
<span class="material-symbols-outlined text-xs">check_circle</span>
</button>
<button class="flex items-center gap-2 px-4 py-2 rounded-full border border-slate-200 dark:border-slate-700 hover:border-primary hover:bg-primary/5 transition-all">
<span class="material-symbols-outlined text-pink-500 text-sm">print</span>
<span class="text-sm font-medium">מדפסת</span>
</button>
</div>
</section>
</div>
<!-- Right Column: Visuals -->
<div class="lg:col-span-5 space-y-6">
<!-- Photo Upload -->
<section class="bg-white dark:bg-slate-900 p-6 rounded-xl mac-shadow border border-slate-100 dark:border-slate-800">
<h2 class="text-lg font-bold mb-4 flex items-center gap-2">
<span class="material-symbols-outlined text-primary">add_a_photo</span>
                        תמונת המשאב
                    </h2>
<div class="relative aspect-video rounded-xl bg-slate-50 dark:bg-slate-800 border-2 border-dashed border-slate-300 dark:border-slate-700 flex flex-col items-center justify-center gap-3 overflow-hidden group cursor-pointer hover:bg-slate-100 dark:hover:bg-slate-750 transition-all">
<img class="absolute inset-0 w-full h-full object-cover opacity-60 group-hover:scale-105 transition-transform" data-alt="Modern high-tech conference room with large window" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCJpQmj2HK3bGysI0qt3nEBGQ7nEiTgECLV_2I9GuriKDsB2H9MnJdccbugzrmzshWHvKVjC4OhJdJyb54aO3XtVwYKksUsv4uTukZrUbB1qPqFaR975r6W5w7Wcg4Cd7_S_K0cdB6DBkHHj4ools_8d5gnPUisetg8OnbSfWK6mf2IO4PD4b38bfVyiTZ-QYGahejxo6IqHSKW_nzxwXZsF6ENS4XIRqUNH2rV9_D6klAdxhgduMn4dBifKg4uEzFkQOdWOcG7KokC"/>
<div class="relative z-10 flex flex-col items-center text-slate-700 dark:text-slate-200">
<span class="material-symbols-outlined text-4xl mb-2">upload_file</span>
<span class="font-bold">העלאת תמונה</span>
<span class="text-xs opacity-75">PNG, JPG עד 5MB</span>
</div>
</div>
</section>
<!-- Map Location -->
<section class="bg-white dark:bg-slate-900 p-6 rounded-xl mac-shadow border border-slate-100 dark:border-slate-800 flex-1">
<h2 class="text-lg font-bold mb-4 flex items-center justify-between">
<div class="flex items-center gap-2">
<span class="material-symbols-outlined text-primary">map</span>
                            מיקום בתוכנית הקומה
                        </div>
<button class="text-xs text-primary font-bold bg-primary/10 px-2 py-1 rounded">מסך מלא</button>
</h2>
<div class="relative aspect-square bg-slate-100 dark:bg-slate-800 rounded-xl overflow-hidden border border-slate-200 dark:border-slate-700" data-location="Tel Aviv" style="">
<!-- Simulated Floor Map -->
<div class="absolute inset-0 p-4">
<div class="w-full h-full bg-white dark:bg-slate-900 rounded border border-slate-200 dark:border-slate-700 p-4 opacity-50">
<div class="grid grid-cols-4 gap-2 h-full">
<div class="bg-slate-200 dark:bg-slate-700 rounded-sm"></div>
<div class="bg-slate-200 dark:bg-slate-700 rounded-sm col-span-2"></div>
<div class="bg-slate-200 dark:bg-slate-700 rounded-sm"></div>
<div class="bg-slate-200 dark:bg-slate-700 rounded-sm"></div>
<div class="bg-slate-200 dark:bg-slate-700 rounded-sm"></div>
<div class="bg-slate-200 dark:bg-slate-700 rounded-sm"></div>
<div class="bg-slate-200 dark:bg-slate-700 rounded-sm"></div>
</div>
</div>
</div>
<!-- Marker -->
<div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 flex flex-col items-center animate-bounce">
<span class="material-symbols-outlined text-primary text-4xl drop-shadow-lg" style="font-variation-settings: 'FILL' 1">location_on</span>
<div class="bg-primary text-white text-[10px] font-bold px-2 py-0.5 rounded-full whitespace-nowrap mac-shadow">גרור למיקום</div>
</div>
<!-- Controls -->
<div class="absolute bottom-4 right-4 flex flex-col gap-2">
<button class="w-8 h-8 bg-white dark:bg-slate-700 rounded-lg mac-shadow flex items-center justify-center text-slate-700 dark:text-white">
<span class="material-symbols-outlined text-xl">add</span>
</button>
<button class="w-8 h-8 bg-white dark:bg-slate-700 rounded-lg mac-shadow flex items-center justify-center text-slate-700 dark:text-white">
<span class="material-symbols-outlined text-xl">remove</span>
</button>
</div>
</div>
<p class="text-xs text-slate-500 mt-3 flex items-center gap-1">
<span class="material-symbols-outlined text-sm">info</span>
                        לחץ וגרור את הסיכה כדי לסמן את מיקום המשאב המדויק
                    </p>
</section>
</div>
</div>
<!-- Sticky Footer Actions -->
<footer class="mt-10 flex items-center justify-end gap-4 pb-12">
<button class="px-8 py-3 rounded-lg font-bold text-slate-600 dark:text-slate-400 hover:bg-slate-200 dark:hover:bg-slate-800 transition-colors">
                ביטול
            </button>
<button class="px-10 py-3 bg-primary text-white rounded-lg font-bold mac-shadow hover:bg-primary/90 transition-all active:scale-95 flex items-center gap-2">
                יצירת משאב
                <span class="material-symbols-outlined">arrow_back</span>
</button>
</footer>
</div>
</body></html>
